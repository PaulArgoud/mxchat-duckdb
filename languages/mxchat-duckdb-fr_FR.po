#: mxchat-duckdb.php
msgid "The MxChat plugin (mxchat-basic) must be installed and activated for this companion plugin to work."
msgstr "Le plugin MxChat (mxchat-basic) doit être installé et activé pour que ce plugin compagnon fonctionne."

#: includes/class-duckdb-motherduck-connection.php
msgid "MotherDuck token is not configured."
msgstr "Le token MotherDuck n'est pas configuré."

#: includes/class-duckdb-motherduck-connection.php
msgid "Invalid MotherDuck database name (letters, digits and underscore only)."
msgstr "Nom de base MotherDuck invalide (lettres, chiffres et underscore uniquement)."

#: includes/class-duckdb-embedded-connection.php
msgid "Embedded DuckDB mode: neither the PHP duckdb extension nor the CLI binary is available. Install ext-duckdb (PECL) or set the binary path in the plugin settings."
msgstr "Mode embedded DuckDB : ni l'extension PHP duckdb ni le binaire CLI ne sont disponibles. Installez ext-duckdb (PECL) ou indiquez le chemin du binaire dans les réglages du plugin."

#: includes/class-duckdb-embedded-connection.php
msgid "DuckDB native extension error: "
msgstr "Erreur DuckDB (extension native) : "

#: includes/class-duckdb-embedded-connection.php
msgid "Failed to launch the DuckDB CLI binary."
msgstr "Impossible de lancer le binaire DuckDB CLI."

#: includes/class-duckdb-embedded-connection.php
#. translators: 1: exit code, 2: stderr content
msgid "DuckDB CLI failed (exit code %1$d): %2$s"
msgstr "DuckDB CLI a échoué (code de sortie %1$d) : %2$s"

#: includes/class-duckdb-embedded-connection.php
msgid "no error output"
msgstr "aucune sortie d'erreur"

#: includes/class-duckdb-embedded-connection.php
msgid "Non-numeric value in array parameter: "
msgstr "Valeur non numérique dans un paramètre tableau : "

#: includes/class-duckdb-vector-store.php
#. translators: 1: vector id, 2: expected dim, 3: actual dim
msgid "Embedding dimension mismatch on upsert: vector_id=%1$s, expected %2$d, got %3$d."
msgstr "Dimension d'embedding incohérente à l'upsert : vector_id=%1$s, attendu %2$d, reçu %3$d."

#: includes/class-duckdb-vector-store.php
#. translators: 1: expected dim, 2: actual dim
msgid "Embedding dimension mismatch: expected %1$d, got %2$d. Update embedding_dim or re-sync."
msgstr "Dimension d'embedding incohérente : attendu %1$d, reçu %2$d. Mettez à jour embedding_dim ou relancez une synchronisation."

#: includes/class-duckdb-vector-store.php
#. translators: 1: index, 2: PHP type name
msgid "Non-numeric embedding component at index %1$d (type %2$s). Refusing to write a corrupted vector."
msgstr "Composante d'embedding non numérique à l'index %1$d (type %2$s). Refus d'écrire un vecteur corrompu."

#: includes/class-duckdb-options.php
#. translators: 1: row count, 2: current dim, 3: requested dim
msgid "Cannot change the embedding dimension: the table already contains %1$d vectors at dimension %2$d. Wipe the table and re-sync to adopt %3$d."
msgstr "Impossible de changer la dimension d'embedding : la table contient déjà %1$d vecteurs en dimension %2$d. Videz la table et relancez une synchronisation pour adopter %3$d."

#: includes/class-duckdb-sync.php
msgid "MxChat_Utils is not available — is mxchat-basic activated?"
msgstr "MxChat_Utils est introuvable — le plugin mxchat-basic est-il activé ?"

#: includes/class-duckdb-sync.php
msgid "No embedding API key configured in MxChat."
msgstr "Aucune clé d'API d'embedding configurée dans MxChat."

#: includes/class-duckdb-search-adapter.php
#. translators: %s = underlying error message
msgid "vector search error — %s"
msgstr "erreur lors de la recherche vectorielle — %s"

#: includes/class-duckdb-admin.php
msgid "DuckDB / MotherDuck"
msgstr "DuckDB / MotherDuck"

#: includes/class-duckdb-admin.php
msgid "MxChat DuckDB"
msgstr "MxChat DuckDB"

#: includes/class-duckdb-admin.php
msgid "Testing…"
msgstr "Test en cours…"

#: includes/class-duckdb-admin.php
msgid "Syncing…"
msgstr "Synchronisation…"

#: includes/class-duckdb-admin.php
msgid "OK"
msgstr "OK"

#: includes/class-duckdb-admin.php
msgid "Error"
msgstr "Erreur"

#: includes/class-duckdb-admin.php
msgid "Sync complete"
msgstr "Synchronisation terminée"

#: includes/class-duckdb-admin.php
#. translators: 1: done count, 2: total count
msgid "Reprocessing %1$d / %2$d…"
msgstr "Retraitement %1$d / %2$d…"

#: includes/class-duckdb-admin.php
#. translators: 1: processed count, 2: failed count
msgid "Reprocess complete: %1$d processed, %2$d failed."
msgstr "Retraitement terminé : %1$d traités, %2$d échecs."

#: includes/class-duckdb-admin.php
msgid "This will call the embedding API for every post (potential cost). Continue?"
msgstr "Cela va appeler l'API d'embedding pour chaque post (coût potentiel). Continuer ?"

#: includes/class-duckdb-admin.php
msgid "Insufficient permissions."
msgstr "Permissions insuffisantes."

#: includes/class-duckdb-admin.php
msgid "Ping failed."
msgstr "Le ping a échoué."

#: admin/views/settings.php
msgid "MxChat — DuckDB / MotherDuck"
msgstr "MxChat — DuckDB / MotherDuck"

#: admin/views/settings.php
msgid "Replaces Pinecone with DuckDB (embedded) or MotherDuck (cloud) as the vector store. The plugin registers itself with MxChat as an alternative Pinecone backend."
msgstr "Remplace Pinecone par DuckDB (embedded) ou MotherDuck (cloud) comme vector store. Le plugin s'enregistre auprès de MxChat comme un backend Pinecone alternatif."

#: admin/views/settings.php
msgid "Last error:"
msgstr "Dernière erreur :"

#: admin/views/settings.php
msgid "Performance:"
msgstr "Performance :"

#: admin/views/settings.php
msgid "the PHP duckdb extension is not loaded. The plugin falls back to the duckdb CLI binary, which adds 50–200 ms of process-spawn latency per query."
msgstr "l'extension PHP duckdb n'est pas chargée. Le plugin retombe sur le binaire duckdb CLI, ce qui ajoute 50–200 ms de latence par requête (lancement de processus)."

#: admin/views/settings.php
msgid "MotherDuck + CLI mode:"
msgstr "Mode MotherDuck + CLI :"

#: admin/views/settings.php
msgid "each query re-runs the MotherDuck ATTACH (network handshake + token validation). Expect 1–3 s of overhead per call. For production, install the PECL duckdb extension."
msgstr "chaque requête refait l'ATTACH MotherDuck (handshake réseau + validation du token). Comptez 1–3 s de surcoût par appel. En production, installez l'extension PECL duckdb."

#: admin/views/settings.php
msgid "Activation"
msgstr "Activation"

#: admin/views/settings.php
msgid "Enable DuckDB / MotherDuck"
msgstr "Activer DuckDB / MotherDuck"

#: admin/views/settings.php
msgid "Enabled"
msgstr "Activé"

#: admin/views/settings.php
msgid "When enabled, MxChat uses this plugin as its vector store (in place of Pinecone). When disabled, MxChat falls back to its default behaviour."
msgstr "Lorsque activé, MxChat utilise ce plugin comme vector store (en lieu et place de Pinecone). Si désactivé, MxChat retombe sur son comportement par défaut."

#: admin/views/settings.php
msgid "Backend"
msgstr "Backend"

#: admin/views/settings.php
msgid "MotherDuck (cloud, via ATTACH)"
msgstr "MotherDuck (cloud, via ATTACH)"

#: admin/views/settings.php
msgid "DuckDB embedded (local file)"
msgstr "DuckDB embedded (fichier local)"

#: admin/views/settings.php
msgid "MotherDuck"
msgstr "MotherDuck"

#: admin/views/settings.php
msgid "Token"
msgstr "Token"

#: admin/views/settings.php
msgid "MotherDuck token (from <a href=\"https://app.motherduck.com\" target=\"_blank\" rel=\"noopener\">app.motherduck.com</a>)."
msgstr "Token MotherDuck (obtenu sur <a href=\"https://app.motherduck.com\" target=\"_blank\" rel=\"noopener\">app.motherduck.com</a>)."

#: admin/views/settings.php
msgid "Database"
msgstr "Base de données"

#: admin/views/settings.php
msgid "DuckDB embedded"
msgstr "DuckDB embedded"

#: admin/views/settings.php
msgid "Path to the .duckdb file"
msgstr "Chemin du fichier .duckdb"

#: admin/views/settings.php
msgid "Leave empty to use the default wp-content/uploads/mxchat-duckdb-private/ directory (protected by auto-generated .htaccess / web.config)."
msgstr "Laisser vide pour utiliser le dossier par défaut wp-content/uploads/mxchat-duckdb-private/ (protégé par un .htaccess / web.config générés automatiquement)."

#: admin/views/settings.php
msgid "DuckDB CLI binary"
msgstr "Binaire DuckDB CLI"

#: admin/views/settings.php
msgid "Used when the PHP duckdb extension is not installed. Leave empty for autodetection."
msgstr "Utilisé si l'extension PHP duckdb n'est pas installée. Laisser vide pour autodétection."

#: admin/views/settings.php
msgid "Vector schema"
msgstr "Schéma vectoriel"

#: admin/views/settings.php
msgid "Embedding dimension"
msgstr "Dimension d'embedding"

#: admin/views/settings.php
#. translators: %d = detected dimension
msgid "MxChat is currently using dimension %d. This must match the active embedding model."
msgstr "MxChat utilise actuellement une dimension de %d. Doit correspondre au modèle d'embedding actif."

#: admin/views/settings.php
msgid "Metric"
msgstr "Métrique"

#: admin/views/settings.php
msgid "MxChat uses cosine similarity — keep cosine unless you have a specific reason."
msgstr "MxChat utilise la similarité cosinus — gardez cosine sauf cas spécifique."

#: admin/views/settings.php
msgid "HNSW index"
msgstr "Index HNSW"

#: admin/views/settings.php
msgid "Create an HNSW index over the embedding column (recommended for > 10k entries)"
msgstr "Créer un index HNSW sur le vecteur (recommandé pour > 10k entrées)"

#: admin/views/settings.php
msgid "Default top-K"
msgstr "Top-K par défaut"

#: admin/views/settings.php
msgid "Save"
msgstr "Enregistrer"

#: admin/views/settings.php
msgid "Diagnostics"
msgstr "Diagnostics"

#: admin/views/settings.php
msgid "Test connection"
msgstr "Tester la connexion"

#: admin/views/settings.php
msgid "Sync MySQL → DuckDB"
msgstr "Sync MySQL → DuckDB"

#: admin/views/settings.php
msgid "Reprocess all posts"
msgstr "Retraiter tous les posts"

#: admin/views/settings.php
msgid "copies the wp_mxchat_system_prompt_content table into DuckDB. Useful only if MxChat is running in MySQL mode and the table contains embeddings."
msgstr "copie la table wp_mxchat_system_prompt_content vers DuckDB. Utile uniquement si MxChat tourne en mode MySQL et que la table contient les embeddings."

#: admin/views/settings.php
msgid "walks WordPress posts/pages and re-runs the MxChat ingestion pipeline (chunking + embedding + upsert). Recommended for Pinecone-only installs. Calls the configured embedding API (OpenAI / Voyage / Gemini) — potential cost."
msgstr "parcourt les posts/pages WordPress et relance le pipeline d'ingestion MxChat (chunking + embedding + upsert). Recommandé pour les installations Pinecone-only. Appelle l'API d'embedding configurée (OpenAI / Voyage / Gemini) — coût potentiel."

#: admin/views/settings.php
msgid "Post types to reprocess (comma-separated):"
msgstr "Post types à retraiter (séparés par virgule) :"

#: admin/views/settings.php
msgid "Vectors in DuckDB"
msgstr "Vecteurs en DuckDB"

#: admin/views/settings.php
msgid "Last sync"
msgstr "Dernière synchronisation"

#: admin/views/settings.php
#. translators: 1: date/time, 2: vector count
msgid "%1$s (%2$d vectors)"
msgstr "%1$s (%2$d vecteurs)"

#: admin/views/settings.php
msgid "Never"
msgstr "Jamais"

#: admin/views/settings.php
msgid "Active backend"
msgstr "Backend actif"

#: admin/views/settings.php
msgid "Pinecone proxy endpoint (Option B)"
msgstr "Endpoint du proxy Pinecone (Option B)"

#: admin/views/settings.php
msgid "These values are auto-injected into MxChat via the mxchat_get_bot_pinecone_config filter. No action required."
msgstr "Ces valeurs sont injectées automatiquement dans MxChat via le filtre mxchat_get_bot_pinecone_config. Aucune action n'est requise."

#: admin/views/settings.php
msgid "Host (for MxChat)"
msgstr "Host (pour MxChat)"

#: admin/views/settings.php
msgid "Api-Key"
msgstr "Clé API"
